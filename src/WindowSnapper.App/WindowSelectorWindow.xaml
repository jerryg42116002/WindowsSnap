<Window x:Class="WindowSnapper.App.WindowSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="窗口选择器"
        Height="560"
        Width="760"
        MinHeight="420"
        MinWidth="620">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel LastChildFill="False">
      <TextBlock Text="窗口选择器"
                 FontSize="22"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
      <Button DockPanel.Dock="Right"
              MinWidth="88"
              Padding="12,6"
              Content="刷新"
              Command="{Binding RefreshCommand}" />
    </DockPanel>

    <TextBlock Grid.Row="1"
               Margin="0,8,0,12"
               Text="{Binding StatusMessage}" />

    <ListBox Grid.Row="2"
             x:Name="WindowList"
             ItemsSource="{Binding Windows}"
             SelectedItem="{Binding SelectedWindow, Mode=TwoWay}"
             SelectionMode="Extended"
             SelectionChanged="OnWindowSelectionChanged"
             HorizontalContentAlignment="Stretch">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid Margin="0,6">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding DisplayName}"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Row="1"
                       Margin="0,4,0,0"
                       Foreground="#666666"
                       Text="{Binding Details}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="2"
                       Margin="0,4,0,0"
                       Foreground="#2F6F4E"
                       Text="{Binding AssignmentText}"
                       TextWrapping="Wrap" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Grid Grid.Row="3"
          Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <StackPanel>
        <TextBlock Text="布局"
                   FontWeight="SemiBold" />
        <ComboBox Margin="0,6,0,0"
                  ItemsSource="{Binding Layouts}"
                  SelectedItem="{Binding SelectedLayout, Mode=TwoWay}"
                  DisplayMemberPath="Name" />
      </StackPanel>

      <StackPanel Grid.Column="2">
        <TextBlock Text="区域 / 起始区域"
                   FontWeight="SemiBold" />
        <ComboBox Margin="0,6,0,0"
                  ItemsSource="{Binding Zones}"
                  SelectedItem="{Binding SelectedZone, Mode=TwoWay}"
                  DisplayMemberPath="DisplayName" />
      </StackPanel>
    </Grid>

    <DockPanel Grid.Row="4"
               LastChildFill="False"
               Margin="0,12,0,0">
      <StackPanel>
        <TextBlock Text="{Binding SelectedWindowCountText}" />
        <TextBlock Margin="0,4,0,0"
                   Text="{Binding AssignmentSummaryText}" />
        <TextBlock Margin="0,4,0,0"
                   Text="{Binding RestoreSummaryText}" />
        <TextBlock Margin="0,4,0,0"
                   Text="{Binding ErrorMessage}"
                   Foreground="#8A1F11"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
      </StackPanel>

      <StackPanel DockPanel.Dock="Right"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button MinWidth="72"
                Margin="0,0,8,0"
                Padding="12,6"
                Content="选定"
                Command="{Binding SelectTargetCommand}" />
        <Button MinWidth="96"
                Margin="0,0,8,0"
                Padding="12,6"
                Content="移动窗口"
                Command="{Binding MoveCommand}" />
        <Button MinWidth="72"
                Margin="0,0,8,0"
                Padding="12,6"
                Content="还原"
                Command="{Binding RestoreCommand}" />
        <Button MinWidth="72"
                Padding="12,6"
                Content="关闭"
                Command="{Binding CloseCommand}" />
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
