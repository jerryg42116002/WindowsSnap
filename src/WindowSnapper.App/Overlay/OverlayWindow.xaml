<Window x:Class="WindowSnapper.App.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowSnapperOverlayWindow"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        IsHitTestVisible="False">
  <Border x:Name="PreviewBorder"
          Background="#4A90E2"
          BorderBrush="#1D4ED8"
          BorderThickness="2"
          CornerRadius="4" />
</Window>
