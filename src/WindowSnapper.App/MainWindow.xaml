<Window x:Class="WindowSnapper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowSnapper"
        Height="280"
        Width="440"
        MinHeight="240"
        MinWidth="400">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="WindowSnapper"
               FontSize="24"
               FontWeight="SemiBold" />

    <TextBlock Grid.Row="1"
               Margin="0,8,0,0"
               Text="{Binding StatusMessage}" />

    <StackPanel Grid.Row="2"
                Margin="0,24,0,0">
      <TextBlock Text="{Binding HotkeyStatusText}"
                 FontWeight="SemiBold" />
    </StackPanel>

    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button MinWidth="96"
              Margin="0,0,8,0"
              Padding="12,6"
              Content="{Binding ToggleHotkeysText}"
              Command="{Binding ToggleHotkeysCommand}" />
      <Button MinWidth="72"
              Margin="0,0,8,0"
              Padding="12,6"
              Content="设置"
              Command="{Binding OpenSettingsCommand}" />
      <Button MinWidth="72"
              Padding="12,6"
              Content="退出"
              Command="{Binding ExitCommand}" />
    </StackPanel>
  </Grid>
</Window>
